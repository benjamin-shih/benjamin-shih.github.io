---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";

const profileLinks = profile.links.filter((link) => link.label !== "Email");
---

<BaseLayout title="Contact | Benjamin Shih" description="Contact Benjamin Shih and find academic profiles, publications, and professional links.">
  <header class="page-heading">
    <h1>Contact</h1>
  </header>

  <section>
    <h2>Email</h2>
    <p><a href={`mailto:${profile.email}`}>{profile.email}</a></p>
  </section>

  <section>
    <h2>Profiles and links</h2>
    <ul>
      {profileLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
    </ul>
  </section>
</BaseLayout>
