---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";

const profileLinks = profile.links.filter((link) => link.label !== "Email");
---

<BaseLayout title="Contact | Benjamin Shih" description="Contact links for Benjamin Shih.">
  <header class="page-heading">
    <h1>Contact</h1>
    <p>For research questions, collaboration, or CV requests, Stanford email is the best contact address.</p>
  </header>

  <section>
    <h2>Email</h2>
    <p><a href={`mailto:${profile.email}`}>{profile.email}</a></p>
    <p>CV and additional materials are available upon request.</p>
  </section>

  <section>
    <h2>Profiles and links</h2>
    <ul>
      {profileLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
    </ul>
  </section>
</BaseLayout>
