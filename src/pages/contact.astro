---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";
---

<BaseLayout title="Contact | Benjamin Shih" description="Contact links for Benjamin Shih.">
  <section class="hero narrow-hero">
    <p class="eyebrow">Contact</p>
    <h1>Get in touch</h1>
    <p class="lede">
      For launch, my Stanford email remains the best contact address.
    </p>
  </section>

  <section class="section two-column balanced">
    <article class="card contact-card">
      <p class="eyebrow">Email</p>
      <h2><a href={`mailto:${profile.email}`}>{profile.email}</a></h2>
      <p class="muted">CV and additional materials are available upon request.</p>
    </article>

    <article class="card contact-card">
      <p class="eyebrow">Profiles</p>
      <div class="contact-list">
        {profile.links.filter((link) => link.label !== "Email").map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </article>
  </section>
</BaseLayout>
