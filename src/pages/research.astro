---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publications, researchHistory, talks, thesis } from "../data/profile";
---

<BaseLayout title="Research | Benjamin Shih" description="Research interests, publications, thesis, and talks by Benjamin Shih.">
  <header class="page-heading">
    <h1>Research</h1>
    <p>
      My research spans mechanistic interpretability and theoretical and scientific machine learning.
    </p>
  </header>

  <section>
    <h2>Research overview</h2>
    <p>
      In the DASH Lab at Stanford, advised by Eric Darve, I investigate feature organization in language models: how features form hierarchies, absorb one another, and trade off interpretability with model fidelity. This work uses sparse representations and other interpretable model abstractions.
    </p>
    <p>
      Previously at Brown, I worked in the CRUNCH group with Zhongqiang Zhang and George Em Karniadakis on neural operators for differential equations, including transformer-based operator learning in finite-regularity settings.
    </p>
  </section>

  <section>
    <h2>Publications</h2>
    {publications.map((paper) => (
      <article class="publication">
        <p class="publication-title">{paper.title}</p>
        <p>{paper.authors}</p>
        <p class="publication-meta">
          <em>{paper.venue}</em>, {paper.detail}, {paper.year}.
        </p>
        <p class="inline-links">
          {paper.links.map((link, index) => (
            <>
              <a href={link.href}>{link.label}</a>{index < paper.links.length - 1 && <span> / </span>}
            </>
          ))}
        </p>
      </article>
    ))}
  </section>

  <section>
    <h2>Bachelor's thesis</h2>
    <article class="publication">
      <p class="publication-title">{thesis.title}</p>
      <p>{thesis.authors}</p>
      <p class="publication-meta">{thesis.venue}, {thesis.year}.</p>
      <p class="inline-links">
        {thesis.links.map((link, index) => (
          <>
            <a href={link.href}>{link.label}</a>{index < thesis.links.length - 1 && <span> / </span>}
          </>
        ))}
      </p>
    </article>
  </section>

  <section>
    <h2>Research experience</h2>
    {researchHistory.map((item) => (
      <article class="plain-entry">
        <h3>{item.label}</h3>
        <p>{item.description}</p>
        <p class="inline-links">
          {item.links.map((link, index) => (
            <>
              {"href" in link ? <a href={link.href}>{link.label}</a> : <span>{link.label}</span>}{index < item.links.length - 1 && <span> / </span>}
            </>
          ))}
        </p>
      </article>
    ))}
  </section>

  <section>
    <h2>Talks</h2>
    <ul>
      {talks.map((talk) => <li>{talk.title}, {talk.venue}, {talk.year}.</li>)}
    </ul>
  </section>

</BaseLayout>
