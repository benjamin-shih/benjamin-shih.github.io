---
import BaseLayout from "../layouts/BaseLayout.astro";
import { experience, profile, publications, thesis } from "../data/profile";

const featuredPublication = publications[0];
const nextRole = experience[0];
const profileLinks = profile.links.filter((link) => !["Email", "LinkedIn"].includes(link.label));
---

<BaseLayout title="Benjamin Shih" description={profile.description}>
  <div class="home-layout">
    <div class="home-main">
      <section class="intro">
        <h1>Benjamin Shih</h1>
        <p class="lede">
          I am a graduate student at the Stanford Institute for Computational and Mathematical Engineering, working on mechanistic interpretability in the DASH Lab at Stanford, advised by Eric Darve. My current research uses interpretable models and sparse representations to study feature hierarchy, feature absorption, and related structure in language models. In {nextRole.period}, I will join <a href={nextRole.href}>{nextRole.organization}</a> as a Quantitative Researcher in {nextRole.detail}.
        </p>
        <p>
          Previously, I received a B.S. with Honors in Applied Mathematics–Computer Science and a B.A. in Pure Mathematics from Brown University.
        </p>
      </section>

      <section>
        <h2>Research interests</h2>
        <ul class="interest-tabs" aria-label="Research interests">
          {profile.interests.map((interest) => <li>{interest}</li>)}
        </ul>
      </section>

      <section>
        <h2>Selected research</h2>
        <article class="publication">
          <p class="publication-title">{featuredPublication.title}</p>
          <p>{featuredPublication.authors}</p>
          <p class="publication-meta">
            <em>{featuredPublication.venue}</em>, {featuredPublication.detail}, {featuredPublication.year}.
          </p>
          <p class="inline-links">
            {featuredPublication.links.map((link, index) => (
              <>
                <a href={link.href}>{link.label}</a>{index < featuredPublication.links.length - 1 && <span> / </span>}
              </>
            ))}
          </p>
        </article>
        <article class="publication">
          <p class="publication-title">{thesis.title}</p>
          <p>{thesis.authors}</p>
          <p class="publication-meta">{thesis.venue}, {thesis.year}.</p>
          <p class="inline-links">
            {thesis.links.map((link, index) => (
              <>
                <a href={link.href}>{link.label}</a>{index < thesis.links.length - 1 && <span> / </span>}
              </>
            ))}
          </p>
        </article>
      </section>

      <section>
        <h2>Research direction</h2>
        <p>
          My current work uses mechanistic interpretability to understand how language models organize and use features. I am especially interested in feature hierarchy, feature absorption, and the tradeoffs between interpretability, sparsity, and model fidelity.
        </p>
      </section>

      <section>
        <h2>CV</h2>
        <p>
          Complete CV available upon request. Please contact me at <a href={`mailto:${profile.email}`}>{profile.email}</a>.
        </p>
      </section>
    </div>

    <aside class="profile-rail" aria-label="Profile details">
      <img src="/assets/headshot.png" alt="Benjamin Shih" class="profile-photo" loading="eager" />

      <div class="rail-section">
        <h2>Contact</h2>
        <p><a href={`mailto:${profile.email}`}>{profile.email}</a></p>
        <p>{profile.location}</p>
      </div>

      <div class="rail-section">
        <h2>Links</h2>
        <ul class="plain-link-list">
          {profileLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
        </ul>
      </div>
    </aside>
  </div>
</BaseLayout>
