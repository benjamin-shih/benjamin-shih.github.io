---
import BaseLayout from "../layouts/BaseLayout.astro";
import { experience, profile, publications } from "../data/profile";

const featuredPublication = publications[0];
const nextRole = experience[0];
const profileLinks = profile.links.filter((link) => link.label !== "Email");
---

<BaseLayout title="Benjamin Shih" description={profile.description}>
  <section class="intro">
    <div class="intro-text">
      <h1>Benjamin Shih</h1>
      <p>
        I am a graduate student at the Stanford Institute for Computational and Mathematical Engineering. Previously, I received a B.S. with Honors in Applied Mathematics–Computer Science and a B.A. in Pure Mathematics from Brown University.
      </p>
      <p>
        My interests span scientific and theoretical machine learning, approximation theory, high-dimensional statistics, and quantitative research.
      </p>
      <p class="contact-line">
        Email: <a href={`mailto:${profile.email}`}>{profile.email}</a>
      </p>
      <p class="inline-links">
        {profileLinks.map((link, index) => (
          <>
            <a href={link.href}>{link.label}</a>{index < profileLinks.length - 1 && <span> · </span>}
          </>
        ))}
      </p>
    </div>
    <img src="/assets/headshot.png" alt="Benjamin Shih" class="profile-photo" loading="eager" />
  </section>

  <section>
    <h2>Research interests</h2>
    <ul>
      {profile.interests.map((interest) => <li>{interest}</li>)}
    </ul>
  </section>

  <section>
    <h2>Selected research</h2>
    <article class="publication">
      <p>
        <strong>{featuredPublication.authors}</strong>, “{featuredPublication.title},” <em>{featuredPublication.venue}</em>, {featuredPublication.year}.
      </p>
      <p class="inline-links">
        {featuredPublication.links.map((link, index) => (
          <>
            <a href={link.href}>{link.label}</a>{index < featuredPublication.links.length - 1 && <span> · </span>}
          </>
        ))}
      </p>
    </article>
  </section>

  <section>
    <h2>Professional background</h2>
    <p>
      In {nextRole.period}, I will join <a href={nextRole.href}>{nextRole.organization}</a> as a {nextRole.title.toLowerCase()} in {nextRole.detail}. My previous internships span quantitative trading, macro relative value, and ML-driven alpha research.
    </p>
  </section>

  <section>
    <h2>CV</h2>
    <p>
      Complete CV available upon request. Please contact me at <a href={`mailto:${profile.email}`}>{profile.email}</a>.
    </p>
  </section>
</BaseLayout>
