---
import BaseLayout from "../layouts/BaseLayout.astro";
import { education, experience, outside, profile, teaching } from "../data/profile";
---

<BaseLayout title="Background | Benjamin Shih" description="Education, professional experience, teaching, and selected background for Benjamin Shih.">
  <header class="page-heading">
    <h1>Background</h1>
    <p>A concise public background page. A complete CV is available upon request.</p>
  </header>

  <section>
    <h2>Education</h2>
    <div class="entry-list">
      {education.map((item) => (
        <article class="dated-entry">
          <p class="date">{item.period}</p>
          <div>
            <h3>{item.institution}</h3>
            <p>{item.degree}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <h2>Professional experience</h2>
    <div class="entry-list">
      {experience.map((item) => (
        <article class="dated-entry">
          <p class="date">{item.period}</p>
          <div>
            <h3><a href={item.href}>{item.organization}</a></h3>
            <p>{item.title}. {item.detail}.</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <h2>Teaching</h2>
    <div class="entry-list">
      {teaching.map((item) => (
        <article class="dated-entry">
          <p class="date">{item.period}</p>
          <div>
            <h3><a href={item.href}>{item.course}</a></h3>
            <p>{item.institution}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <h2>Outside school and work</h2>
    <ul>
      {outside.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section>
    <h2>CV</h2>
    <p>
      Complete CV available upon request. Please email <a href={`mailto:${profile.email}`}>{profile.email}</a>.
    </p>
  </section>
</BaseLayout>
